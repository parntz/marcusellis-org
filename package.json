{
  "name": "get-site-generated",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:content": "node scripts/generate-site-data.mjs",
    "db:init": "node scripts/db-init.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:sync:news-events": "node scripts/db-sync-news-events.mjs",
    "db:sync:member-pages": "node scripts/db-sync-member-pages.mjs",
    "db:prepare": "npm run db:init && npm run db:sync:news-events",
    "predev": "node scripts/predev.mjs",
    "prebuild": "npm run generate:content && npm run db:prepare",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@netlify/blobs": "^10.7.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35"
  }
}
